# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Apple signing keys — NEVER commit these. Sign in with Apple .p8 files,
# distribution certs, provisioning profiles. The .p8 in particular is a
# private RSA key and Apple lets you download it exactly once, so a
# repo leak is permanent and forces a key rotation.
*.p8
*.p12
*.cer
*.mobileprovision
ios/AuthKey_*.p8

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
supabase/.temp/

# harvest caches (Met API JSON, regenerated by scripts/harvest-met.mjs)
/.met-cache/

# content packs (built by scripts/build-content-packs.ts; uploaded to Supabase Storage)
/dist/
