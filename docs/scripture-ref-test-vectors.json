{
  "$schema_note": "Shared test vectors for the canonical scripture-reference parser. Every client (Swift, Kotlin, TypeScript) must round-trip these strings byte-for-byte. The 'parse' direction maps a string to its component fields; the 'format' direction maps the fields back to the string.",
  "format_grammar": "<book-slug>.<chapter>[.<verse>][-<verse_end>]",
  "rules": [
    "book-slug is lowercase; multi-word books are hyphenated (1-corinthians, song-of-solomon)",
    "chapter is required and >= 1",
    "verse is optional; when present it is >= 1",
    "verse range uses an ASCII hyphen (no en-dash); verse_end > verse_start",
    "no whitespace anywhere",
    "the canonical form is the same as the parser's normalized output — there is no aliasing"
  ],
