# ============================================
# Supabase (required for app to boot)
# ============================================
# Find these at: https://supabase.com/dashboard/project/<your-loc-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — needed for /api/admin/* routes and scripts
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# Admin (artwork moderation UI)
# ============================================
# Any random long string — required to call /api/admin/* routes
ADMIN_API_KEY=

# ============================================
# Artwork moderation providers (optional but recommended)
# ============================================
# OpenAI Vision — used by src/lib/moderation
OPENAI_API_KEY=

# AWS Rekognition — used by src/lib/moderation
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ============================================
# Script tuning (optional)
# ============================================
# MOD_CONCURRENCY=4
# SKIP_VERIFY=
